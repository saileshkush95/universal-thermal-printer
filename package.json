{
  "name": "universal-thermal-printer",
  "version": "0.6.0",
  "type": "module",
  "description": "Print to thermal (ESC/POS) and A4 (PDF) printers via TCP, Bluetooth, USB, or system spooler — works in Node.js, Bun, Electron, and Expo",
  "license": "MIT",
  "author": "Sandeep Kushwaha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saileshkush95/universal-thermal-printer.git"
  },
  "bugs": {
    "url": "https://github.com/saileshkush95/universal-thermal-printer/issues"
  },
  "homepage": "https://github.com/saileshkush95/universal-thermal-printer#readme",
  "keywords": [
    "thermal-printer",
    "escpos",
    "receipt",
    "printer",
    "bluetooth",
    "usb",
    "tcp",
    "network",
    "pos",
    "point-of-sale",
    "barcode",
    "qr-code",
    "invoice",
    "pdf",
    "a4",
    "react-native",
    "expo",
    "android",
    "ios",
    "electron",
    "node-thermal-printer",
    "cups",
    "spooler",
    "epson",
    "star-micronics",
    "cross-platform",
    "raw-printing",
    "kitchen-display",
    "webusb",
    "web-serial",
    "browser",
    "chrome",
    "zadig",
    "winusb",
    "usbprint",
    "virtual-prn",
    "chrome-webusb",
    "browser-printing"
  ],
  "files": [
    "dist",
    "src",
    "android",
    "plugin",
    "docs",
    "react-native.config.js",
    "LICENSE",
    "README.md"
  ],
  "main": "dist/index.js",
  "react-native": "dist/index.rn.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thermal-print": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.web.js",
      "react-native": "./dist/index.rn.js",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/index.web.d.ts",
      "import": "./dist/index.web.js"
    },
    "./plugin/withUsbPrinter": "./plugin/withUsbPrinter.js",
    "./package.json": "./package.json"
  },
  "expo": {
    "autolinking": {
      "nativeModules": [
        "universal-thermal-printer"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "build:web": "tsc --outDir dist --rootDir src && cp dist/index.web.js dist/index.web.mjs",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "peerDependencies": {
    "bluetooth-serial-port": "^3.0.2",
    "pdf-lib": "^1.17.1",
    "react-native-ble-plx": "^3.0.0",
    "react-native-tcp-socket": "^6.0.0 || ^7.0.0",
    "serialport": "^12.0.0 || ^13.0.0"
  },
  "peerDependenciesMeta": {
    "bluetooth-serial-port": {
      "optional": true
    },
    "pdf-lib": {
      "optional": true
    },
    "react-native-ble-plx": {
      "optional": true
    },
    "react-native-tcp-socket": {
      "optional": true
    },
    "serialport": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "pdf-lib": "^1.17.1",
    "typescript": "^6.0.3"
  }
}
