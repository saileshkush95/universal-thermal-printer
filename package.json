{
  "name": "universal-thermal-printer",
  "version": "0.1.0",
  "type": "module",
  "description": "Print to thermal printers via TCP, Bluetooth, or USB — works in Node.js and Bun",
  "license": "MIT",
  "author": "Sandeep Kushwaha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saileshkush95/universal-thermal-printer.git"
  },
  "bugs": {
    "url": "https://github.com/saileshkush95/universal-thermal-printer/issues"
  },
  "homepage": "https://github.com/saileshkush95/universal-thermal-printer#readme",
  "keywords": [
    "thermal-printer",
    "escpos",
    "pos",
    "receipt",
    "printer",
    "bluetooth",
    "usb",
    "tcp",
    "network"
  ],
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thermal-print": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "bluetooth-serial-port": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "serialport": "^12.0.0 || ^13.0.0"
  },
  "peerDependenciesMeta": {
    "serialport": {
      "optional": true
    },
    "bluetooth-serial-port": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  }
}
