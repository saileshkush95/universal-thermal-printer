{
  "name": "universal-thermal-printer",
  "version": "0.2.1",
  "type": "module",
  "description": "Print to thermal printers via TCP, Bluetooth, or USB — works in Node.js, Bun, and Expo",
  "license": "MIT",
  "author": "Sandeep Kushwaha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saileshkush95/universal-thermal-printer.git"
  },
  "bugs": {
    "url": "https://github.com/saileshkush95/universal-thermal-printer/issues"
  },
  "homepage": "https://github.com/saileshkush95/universal-thermal-printer#readme",
  "keywords": [
    "thermal-printer",
    "escpos",
    "pos",
    "receipt",
    "printer",
    "bluetooth",
    "usb",
    "tcp",
    "network",
    "expo",
    "react-native"
  ],
  "files": [
    "dist",
    "src",
    "android",
    "plugin",
    "react-native.config.js",
    "LICENSE",
    "README.md"
  ],
  "main": "dist/index.js",
  "react-native": "dist/index.rn.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thermal-print": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.rn.js",
      "import": "./dist/index.js"
    },
    "./plugin/withUsbPrinter": "./plugin/withUsbPrinter.js",
    "./package.json": "./package.json"
  },
  "expo": {
    "autolinking": {
      "nativeModules": ["universal-thermal-printer"]
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "peerDependencies": {
    "bluetooth-serial-port": "^3.0.2",
    "expo-ble": "*",
    "react-native-tcp-socket": "^6.0.0 || ^7.0.0",
    "serialport": "^12.0.0 || ^13.0.0"
  },
  "peerDependenciesMeta": {
    "bluetooth-serial-port": {
      "optional": true
    },
    "expo-ble": {
      "optional": true
    },
    "react-native-tcp-socket": {
      "optional": true
    },
    "serialport": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
